# ==============================
# Store APIs Environment (Example)
# ==============================
APP_ENV=production
APP_DEBUG=false

# ---------- Database ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=store
DB_USER=your_db_user
DB_PASS=your_db_password
DB_TIMEOUT=2
DB_CHARSET=utf8mb4

# ---------- Cookie / Tracking ----------
V_ID_COOKIE_NAME=v_id
V_ID_COOKIE_DAYS=365
V_ID_COOKIE_SAMESITE=Lax
V_ID_COOKIE_HTTPONLY=false

# Force cookie secure flag. Keep empty to auto-detect from HTTPS.
V_ID_COOKIE_SECURE=

# ---------- API / CORS ----------
# Leave empty to disable cross-origin requests (recommended default).
# For production, use only your real domains (comma-separated), e.g.
# API_CORS_ALLOW_ORIGIN=https://yourstore.com,https://www.yourstore.com
API_CORS_ALLOW_ORIGIN=https://yourstore.com,https://www.yourstore.com
API_CORS_ALLOW_METHODS=GET, POST, OPTIONS
API_CORS_ALLOW_HEADERS=Content-Type, Authorization, X-Requested-With
API_CORS_ALLOW_CREDENTIALS=false
API_CORS_MAX_AGE=600
